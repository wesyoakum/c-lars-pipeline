{
  // C-LARS Pipeline.
  // Cloudflare Pages project wired to D1 + R2.
  // Auth is handled entirely by Cloudflare Access in front of the Pages site —
  // middleware decodes the JWT and upserts the user in the D1 users table.
  // The Pages project name (c-lars-pms), D1 database (c-lars-pms-db), and R2
  // bucket (c-lars-pms-docs) all keep their legacy names. Cloudflare doesn't
  // support renaming Pages projects in place; D1/R2 renames would require
  // data migration. These are internal Cloudflare IDs, never user-visible.
  "name": "c-lars-pms",
  "pages_build_output_dir": ".",
  "compatibility_date": "2026-04-10",

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "c-lars-pms-db",
      "database_id": "50f45535-8f4d-4428-8da1-d4ce4bd24d6e"
    }
  ],

  "r2_buckets": [
    {
      "binding": "DOCS",
      "bucket_name": "c-lars-pms-docs"
    }
  ],

  "vars": {
    // PIPELINE_ENV=production: requests without a Cf-Access-Authenticated-User-Email
    // header return 401. Cloudflare Access is in front of the Pages deployment,
    // so every real request has this header. Local dev overrides PIPELINE_ENV to
    // 'development' via .dev.vars so the dev stub user still works locally.
    //
    // ConvertAPI secret for .docx → PDF conversion is set via
    // `wrangler pages secret put CONVERTAPI_SECRET` (not listed here
    // to avoid binding name conflict).
    //
    // AI provider configuration (set as secrets, not vars):
    //   OPENAI_API_KEY          — audio transcription (Whisper / gpt-4o-transcribe)
    //   ANTHROPIC_API_KEY       — text → structure (Claude Sonnet/Haiku)
    //   AI_GATEWAY_ACCOUNT_ID   — Cloudflare account id (optional)
    //   AI_GATEWAY_NAME         — Cloudflare AI Gateway slug (optional)
    // When AI_GATEWAY_* are set, every AI call routes through the gateway
    // for unified logging, caching, retries, and cost tracking. See
    // functions/lib/ai-gateway.js.
    //
    // Per-step model overrides (optional):
    //   AI_INBOX_TRANSCRIPTION_MODEL   default 'gpt-4o-mini-transcribe'
    //   AI_INBOX_CLASSIFY_MODEL        default Claude Haiku
    //   AI_INBOX_EXTRACT_MODEL         default Claude Sonnet
    //   ANTHROPIC_MODEL                 global default for Anthropic calls
    "PIPELINE_ENV": "production",
    "CF_ACCESS_TEAM_DOMAIN": "c-lars.cloudflareaccess.com",
    "CF_ACCESS_AUD": ""
  }
}
